---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Lucas Pereira de Souza — Desenvolvedor Full-Stack Sênior especializado em React, Node.js e arquiteturas escaláveis." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={new URL("favicon.svg", Astro.url).href} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="dark bg-stone-950">
    <slot />
  </body>
</html>
