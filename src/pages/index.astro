---
import Layout from "../layouts/Layout.astro";
import { TextGenerateEffect } from "@/components/TextGenerative";
import { PortifolioCard } from "@/components/card3d";
import { SparklesPreview } from "@/components/sparkTitle";
import { Vortex } from "@/components/vortext";
import { WobbleCard } from "@/components/wobble-card";
import "@/styles/global.css";
import { TypewriterEffectSmooth } from "@/components/typewriter-effect";
import { Image } from "astro:assets";
import TechCards from "@/components/tech-list";
import ParallaxSection from "@/components/scroll-animation";

const words = [
  {
    text: "Build",
  },
  {
    text: "awesome",
  },
  {
    text: "apps",
  },
  {
    text: "with",
  },
  {
    text: "React.",
    className: "text-blue-500 dark:text-blue-500",
  },
];
// text: "Aceternity.",

const someProps = {
  count: 0,
};

const technologyCards = [
  {
    title: "Frontend moderno",
    description:
      "React, Next.js e TypeScript para interfaces performáticas, reutilizáveis e fáceis de evoluir.",
    image: "/linear.webp",
    alt: "Frontend stack",
    containerClassName:
      "col-span-1 lg:col-span-2 h-full bg-zinc-900 min-h-[420px] lg:min-h-[320px] border border-zinc-800",
    imageClassName:
      "absolute -right-4 lg:-right-[25%] grayscale filter -bottom-10 object-contain rounded-2xl opacity-80",
  },
  {
    title: "Backend e integrações",
    description:
      "Node.js, Express, Kafka e Redis para APIs robustas, mensageria e baixa latência em produção.",
    image: "/linear.webp",
    alt: "Backend stack",
    containerClassName:
      "col-span-1 bg-zinc-900 min-h-[320px] border border-zinc-800",
    imageClassName:
      "absolute -right-6 -bottom-8 object-contain rounded-2xl opacity-70 h-52 w-52",
  },
  {
    title: "DevOps e qualidade",
    description:
      "Docker, Kubernetes e Jest para pipeline confiável, deploy contínuo e qualidade de código consistente.",
    image: "/linear.webp",
    alt: "DevOps stack",
    containerClassName:
      "col-span-1 lg:col-span-3 bg-zinc-900 min-h-[420px] lg:min-h-[360px] xl:min-h-[320px] border border-zinc-800",
    imageClassName:
      "absolute -right-8 md:-right-[20%] lg:-right-[10%] -bottom-12 object-contain rounded-2xl opacity-75",
  },
];

const socialLinks = [
  {
    label: "Instagram",
    href: "https://instagram.com/lucaspereirasouzat",
  },
  {
    label: "GitHub",
    href: "https://github.com/lucaspereirasouzat",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/lucas-pereira-511292142",
  },
  // {
  //   label: "Mastodon",
  //   href: "https://mastodon.social/@SEU_USUARIO",
  // },
  {
    label: "Facebook",
    href: "https://facebook.com/banasplit78",
  },
  {
    label: "Email",
    href: "mailto:lucaspereiradesouzat@gmail.com",
  },
];
---

<Layout title="Welcome to Astro.">
  <body class="h-screen bg-white">
    <!-- header section -->
    <header>
      <div class="w-full mx-auto bg-transparent fixed z-50 text-white">
        <nav class="sm:hidden pt-3 pb-2 bg-white">
          <ul class="flex justify-center gap-10">
            <li class="hover:text-gray-500 text-gray-500">
              <a href="#about">About</a>
            </li>
            <li class="hover:text-gray-500 text-gray-500">
              <a href="#services">Services</a>
            </li>
            <li class="hover:text-gray-500 text-gray-500">
              <a href="#portfolio">Portfolio</a>
            </li>
            <li class="hover:text-gray-500 text-gray-500">
              <a href="#contact">Contact</a>
            </li>
          </ul>
        </nav>
        <nav class="justify-between items-center h-10 p-10 hidden sm:flex">
          <!-- images -->
          <Image
            alt={"port"}
            class="h-5"
            width={100}
            height={100}
            src="https://rabiulislam.dev/documents/images/portfolio/portfolio.png"
          />

          <!-- menu -->
          <ul class="flex gap-10">
            <li class="hover:text-gray-500"><a href="#about">About</a></li>
            <li class="hover:text-gray-500">
              <a href="#services">Services</a>
            </li>
            <li class="hover:text-gray-500">
              <a href="#portfolio">Portfolio</a>
            </li>
            <li class="hover:text-gray-500"><a href="#contact">Contact</a></li>
          </ul>

          <!-- auth -->
          <a
            class="px-5 py-1 bg-gray-50 rounded-full ring-1 ring-gray-100 hover:bg-white"
            href="#">Hire Me</a
          >
        </nav>
      </div>
    </header>
    <div class="w-full mx-auto rounded-md h-screen overflow-hidden">
      <Vortex
        backgroundColor="black"
        rangeY={800}
        particleCount={100}
        baseHue={120}
        client:only="react"
        className="flex items-center flex-col justify-center px-2 md:px-10  py-4 w-full h-full"
      >
        <div class="container mx-auto">
          <div class="flex justify-center align-middle">
            <div
              class="flex flex-col gap-5 text-center w-full justify-center align-middle"
            >
              <!-- <Image
                alt={"profile"}
                width={100}
                height={100}
                class="rounded-full bg-gray-50 h-52 w-56 mx-auto"
                src="/public/profile.jpg"
              /> -->
              <div
                class="flex flex-col gap-3 align-middle justify-center text-center"
              >
                <!-- <SparklesPreview client:only="react" /> -->
                <TextGenerateEffect
                  client:only="react"
                  words="Lucas Pereira de Souza"
                />
                <div class="flex align-middle justify-center text-center">
                  <TypewriterEffectSmooth client:only="react" words={words} />
                </div>
                <div class="space-y-2">
                  <p
                    class="max-w-[600px] text-zinc-200 md:text-xl dark:text-zinc-100 mx-auto"
                  >
                    Join us and take control of your inbox. Fast, secure, and
                    designed for modern life.
                  </p>
                </div>
                <p class="text-gray-500 text-sm shadow-xl drop-shadow-xl">
                  Senior Full Stack Web Developer (React, Nodejs)
                </p>
              </div>
              <!-- <a
                href="#"
                class="bg-gray-50 mx-auto w-32 text-center rounded-md p-2 border border-1 border-gray-100 hover:bg-white"
                >Hire me</a
              > -->
            </div>
          </div>
        </div>
      </Vortex>
    </div>
    <!-- main content -->
    <main class="w-full">
      <!-- about me -->
      <section id="about" class="bg-black shadow-xl w-full p-10">
        <ParallaxSection client:load>
          <div>
            <div class="sm:columns-2">
              <Image
                width={100}
                height={100}
                alt="te"
                class="sm:w-1/3 mb-10 sm:mb-0"
                src="https://media.licdn.com/dms/image/v2/D4D03AQGv3E4OYbJhnw/profile-displayphoto-shrink_200_200/profile-displayphoto-shrink_200_200/0/1727266556771?e=1762387200&v=beta&t=Btr7rpRXIm1bK913kl97mZqr1BpLMawy73XtI0BvYIQ"
              />
              <div>
                <h2 class="text-bold text-2xl mb-3">
                  Full Stack Web Developer
                </h2>
                <p class="mb-5 text-sm text-gray-400">
                  Providing web solutions
                </p>
                <p class="text-gray-500 text-justify leading-10">
                  Sou Desenvolvedor Full-Stack, graduado em Análise de Sistemas,
                  com ampla experiência em tecnologias modernas e um forte
                  alinhamento com a filosofia de Código Aberto, tão valorizada
                  pela comunidade tecnológica. Minha atuação está centrada na
                  linguagem de programação JavaScript, com proficiência em
                  frameworks e bibliotecas de destaque, como ReactJS, Next.js,
                  React Native, AdonisJS e Express. Possuo conhecimentos em
                  sistemas de mensageria distribuída com Kafka, automação de
                  testes utilizando Jest, e orquestração de contêineres através
                  de Kubernetes. Minha experiência se estende também ao uso de
                  bancos de dados relacionais e não-relacionais, como Postgres,
                  MongoDB e Redis, o que me permite lidar com diversas
                  arquiteturas de armazenamento de dados. Além da prática
                  técnica, sou um entusiasta de princípios de engenharia de
                  software de alta qualidade, sendo familiar com as diretrizes
                  apresentadas em obras consagradas como Clean Code,
                  Domain-Driven Design (DDD) e Refatoração. Esses conhecimentos
                  me capacitam a desenvolver soluções robustas, escaláveis e de
                  fácil manutenção, sempre priorizando a clareza e a eficiência
                  no código. Minha carreira é pautada por uma abordagem proativa
                  e colaborativa, sempre em busca de excelência técnica e
                  inovação.
                </p>
              </div>
            </div>
          </div>
        </ParallaxSection>
      </section>

      <TechCards client:only="react" />
      <!-- tecnologies -->
      <section class="lg:p-20 p-5 w-full" id="technologies">
        <ParallaxSection client:load>
          <div class="w-full mx-auto">
            <h2 class="text-center text-4xl font-bold pb-10">Tecnologias</h2>
            <div class="lg:columns-2 sm:columns-1 w-full">
              <div
                class="grid grid-cols-1 lg:grid-cols-3 gap-4 max-w-7xl mx-auto w-full"
              >
                {
                  technologyCards.map((tech) => (
                    <WobbleCard
                      client:only="react"
                      containerClassName={tech.containerClassName}
                    >
                      <div class="max-w-lg">
                        <h2 class="text-left text-balance text-base md:text-xl lg:text-3xl font-semibold tracking-[-0.015em] text-white">
                          {tech.title}
                        </h2>
                        <p class="mt-4 text-left text-base/6 text-zinc-300">
                          {tech.description}
                        </p>
                      </div>
                      <Image
                        src={tech.image}
                        width={500}
                        height={500}
                        alt={tech.alt}
                        class={tech.imageClassName}
                      />
                    </WobbleCard>
                  ))
                }
              </div>
            </div>
          </div>
        </ParallaxSection>
      </section>

      <!-- portfolio -->
      <section class="lg:p-20 p-5" id="portfolio">
        <ParallaxSection client:load>
          <div class="w-full mx-auto">
            <h2 class="text-center text-4xl font-bold pb-10">Portfolio</h2>
            <PortifolioCard client:only="react" />
          </div>
        </ParallaxSection>
      </section>

      <!-- section -->
      <section class="sm:p-20 p-5" id="contact">
        <ParallaxSection client:load>
          <div class="sm:container mx-auto">
            <h2 class="text-center text-4xl font-bold pb-10">Contact</h2>
            <div class="w-full sm:flex">
              <div class="sm:w-1/2 w-full">
                <div class="mb-5">
                  <h3 class="text-xl">Email</h3>
                  <a
                    class="text-gray-500"
                    href="mailto:lucaspereiradesouzat@gmail.com"
                    >lucaspereiradesouzat@gmail.com</a
                  >
                </div>
                <div>
                  <h3 class="text-xl mb-4">Social</h3>
                  <ul class="flex flex-wrap gap-3">
                    {
                      socialLinks.map((social) => (
                        <li>
                          <a
                            href={social.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex rounded-full border border-zinc-700 bg-zinc-900 px-4 py-2 text-sm text-zinc-200 transition-colors hover:bg-zinc-800 hover:text-white"
                          >
                            {social.label}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </div>
              </div>

              <div class="sm:w-1/2 w-full bg-gray-50 p-10 rounded-md">
                <form action="#">
                  <div class="mt-5 grid grid-cols-1 gap-y-8 sm:grid-cols-6">
                    <div class="sm:col-span-4">
                      <label
                        for="username"
                        class="block text-sm font-medium leading-6 text-gray-900"
                        >Name</label
                      >
                      <input
                        type="text"
                        name="username"
                        id="username"
                        autocomplete="username"
                        class="block w-full outline-1 border border-1 flex-1 bg-transparent py-1.5 pl-3 text-gray-900 placeholder:text-gray-400 sm:text-sm sm:leading-6"
                        placeholder="Rabiul Islam"
                      />
                    </div>
                  </div>

                  <div class="mt-5 grid grid-cols-1 gap-y-8 sm:grid-cols-6">
                    <div class="sm:col-span-4">
                      <label
                        for="subject"
                        class="block text-sm font-medium leading-6 text-gray-900"
                        >Subject</label
                      >
                      <input
                        type="text"
                        name="subject"
                        id="subject"
                        autocomplete="subject"
                        class="block w-full outline-1 border border-1 flex-1 bg-transparent py-1.5 pl-3 text-gray-900 placeholder:text-gray-400 sm:text-sm sm:leading-6"
                        placeholder="Hiring"
                      />
                    </div>
                  </div>

                  <div class="mt-5 grid grid-cols-1 gap-y-8 sm:grid-cols-6">
                    <div class="sm:col-span-4">
                      <label
                        for="message"
                        class="block text-sm font-medium leading-6 text-gray-900"
                        >Message</label
                      >
                      <textarea
                        name="message"
                        id="message"
                        autocomplete="message"
                        class="block w-full outline-1 border border-1 flex-1 bg-transparent py-1.5 pl-3 text-gray-900 placeholder:text-gray-400 sm:text-sm sm:leading-6"
                        placeholder="Message"></textarea>
                    </div>
                  </div>

                  <div class="mt-5 grid grid-cols-1 gap-y-8 sm:grid-cols-6">
                    <a
                      href="#"
                      class="bg-gray-200 mx-auto w-32 text-center rounded-md p-2 border border-1 border-gray-100 hover:bg-white"
                      >Submit</a
                    >
                  </div>
                </form>
              </div>
            </div>
          </div>
        </ParallaxSection>
      </section>
    </main>

